{
  "name": "pkstack",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "templates/*"
  ],
  "scripts": {
    "build": "turbo run build --env-mode=loose",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test && npm run test:e2e",
    "test:e2e": "playwright test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "prettier": "3.8.1",
    "turbo": "2.9.5",
    "typescript": "5.9.3"
  },
  "overrides": {
    "@mintlify/previewing": {
      "react": "19.2.5"
    },
    "ink": {
      "react": "19.2.5"
    },
    "ink-spinner": {
      "react": "19.2.5"
    }
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "packageManager": "npm@10.9.0"
}
