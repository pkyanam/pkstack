{
  "name": "create-pkstack",
  "version": "0.2.1",
  "description": "Create an AI-native Next.js app with gstack pre-wired",
  "license": "MIT",
  "type": "module",
  "bin": {
    "create-pkstack": "./dist/index.js"
  },
  "files": [
    "dist/",
    "templates/"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-templates.mjs",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@clack/prompts": "0.9.1",
    "chalk": "5.6.2",
    "ora": "8.2.0",
    "picocolors": "1.1.1",
    "tar": "7.5.13"
  },
  "devDependencies": {
    "@pkstack/config": "0.2.1",
    "@types/node": "22.19.17",
    "@types/tar": "6.1.13",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
