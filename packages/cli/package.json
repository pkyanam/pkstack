{
  "name": "create-pkstack",
  "version": "0.1.1",
  "description": "Create an AI-native Next.js app with gstack pre-wired",
  "license": "MIT",
  "type": "module",
  "bin": {
    "create-pkstack": "./dist/index.js"
  },
  "files": [
    "dist/",
    "templates/"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-templates.mjs",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "chalk": "^5.4.1",
    "ora": "^8.2.0",
    "picocolors": "^1.1.1",
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@pkstack/config": "*",
    "@types/node": "^22.13.14",
    "@types/tar": "^6.1.13",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
