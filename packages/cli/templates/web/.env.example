# Database
# Local: docker compose up -d, then use:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myapp
# Production (Neon): uncomment and fill in:
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# App URL (used by Better Auth for redirects)
BETTER_AUTH_URL=http://localhost:3000

# Optional: Stripe payments (add with: npx create-pkstack add stripe)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional: Resend email (add with: npx create-pkstack add resend)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=noreply@yourdomain.com
