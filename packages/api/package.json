{
  "name": "@pkstack/api",
  "version": "0.2.0",
  "description": "Plain TypeScript API contracts for pkstack apps",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src/",
    "test": "echo 'no tests for @pkstack/api'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@pkstack/config": "0.2.0",
    "@types/node": "22.19.17",
    "eslint": "9.39.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
