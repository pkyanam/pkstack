{
  "name": "@pkstack/ui",
  "version": "0.2.0",
  "description": "Shared React UI primitives for pkstack apps",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src/",
    "prepack": "npm run build",
    "test": "echo 'no tests for @pkstack/ui'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "radix-ui": "1.4.3",
    "tailwind-merge": "3.5.0"
  },
  "peerDependencies": {
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@pkstack/config": "0.2.0",
    "@types/node": "22.19.17",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
